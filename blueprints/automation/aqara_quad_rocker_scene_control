blueprint:
  name: Zigbee2MQTT - H2 Quad Rocker Scene Controller
  description: >
    Control lights, fans, and blinds using the H2 Quad Rocker via Zigbee2MQTT.
    Top: Light Toggle
    Middle: Fan Cycle (Off/33/66/100)
    Bottom: Blind Up/Stop
    Wireless: Blind Down/Stop
  domain: automation
  input:
    z2m_action_topic:
      name: Zigbee2MQTT action topic
      description: e.g., zigbee2mqtt/Bedroom 3 Scene Control/action
      selector:
        text: {}
    light_entity:
      name: Light entity
      selector:
        entity:
          domain: light
    fan_entity:
      name: Fan entity
      selector:
        entity:
          domain: fan
    blind_entity:
      name: Blind/Cover entity
      selector:
        entity:
          domain: cover

mode: parallel
max: 10

trigger:
  - platform: mqtt
    topic: !input z2m_action_topic

variables:
  light: !input light_entity
  fan: !input fan_entity
  blind: !input blind_entity

action:
  - choose:
      # TOP ROCKER: Light Toggle
      - conditions: "{{ trigger.payload == 'single_top' }}"
        sequence:
          - action: light.toggle
            target:
              entity_id: "{{ light }}"

      # CENTER ROCKER: Fan Cycle
      - conditions: "{{ trigger.payload == 'single_center' }}"
        sequence:
          - action: fan.turn_on
            target:
              entity_id: "{{ fan }}"
            data:
              percentage: >
                {% set current = state_attr(fan, 'percentage') | int(0) %}
                {% if current == 0 %} 33
                {% elif current == 33 %} 66
                {% elif current == 66 %} 100
                {% else %} 0
                {% endif %}

      # BOTTOM ROCKER: Blind Up / Stop
      - conditions: "{{ trigger.payload == 'single_bottom' }}"
        sequence:
          - if:
              - condition: template
                value_template: "{{ is_state(blind, 'opening') }}"
            then:
              - action: cover.stop_cover
                target:
                  entity_id: "{{ blind }}"
            else:
              - action: cover.open_cover
                target:
                  entity_id: "{{ blind }}"

      # WIRELESS ROCKER: Blind Down / Stop
      - conditions: "{{ trigger.payload == 'single_wireless' }}"
        sequence:
          - if:
              - condition: template
                value_template: "{{ is_state(blind, 'closing') }}"
            then:
              - action: cover.stop_cover
                target:
                  entity_id: "{{ blind }}"
            else:
              - action: cover.close_cover
                target:
                  entity_id: "{{ blind }}"
